cd $(dirname $BASH_SOURCE)

if [ "$1" = --reset ]; then
  rm -rf .venv .tox build dist htmlcov wasmjs.egg-info
  find -name __pycache__ | xargs -r rm -rf
fi

if [ ! -d .venv ]; then
  python3 -m venv .venv --prompt="$(basename $(readlink -f .))"
fi

if [ ! -f .venv/bin/build ]; then
  echo 'exec python -m build "$@"' > .venv/bin/build
  chmod +x .venv/bin/build
fi

source .venv/bin/activate

pip install -U pip setuptools
pip install -U -e .[dev] build twine

if [ ! -f qjs-wasi-reactor.wasm ]; then
  wget https://github.com/quickjs-ng/quickjs/releases/download/v0.13.0/qjs-wasi-reactor.wasm
fi
